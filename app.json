{
  "expo": {
    "name": "T-Suma",
    "slug": "tienda-app",
    "version": "0.1.1.260427",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F7A59"
    },
    "assetBundlePatterns": [
      "assets/images/*",
      "assets/fonts/*",
      "assets/*.png"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trenkit.tsuma",
      "infoPlist": {
        "UIBackgroundModes": ["fetch"]
      }
    },
    "android": {
      "versionCode": 10,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1F7A59"
      },
      "package": "com.trenkit.tsuma",
      "permissions": [
        "CAMERA",
        "WRITE_EXTERNAL_STORAGE",
        "READ_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d6973b85-728c-4f43-86bb-f97aba791748"
      },
      "storeUpdate": {
        "androidPackage": "com.trenkit.tsuma",
        "versionCheckUrl": "https://raw.githubusercontent.com/sumanuel/tienda-update/main/version.json",
        "timeoutMs": 7000,
        "allowDevChecks": true
      }
    },
    "plugins": ["@react-native-community/datetimepicker", "expo-camera"]
  }
}
